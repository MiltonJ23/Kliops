{
	"info": {
		"name": "Kliops - API Gateway M2",
		"description": "API Gateway test suite: auth middleware, MinIO upload, and pricing strategy routing.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"item": [
		{
			"name": "Health Check",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "http://localhost:8070/health",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8070",
					"path": [
						"health"
					]
				},
				"description": "Public endpoint to verify gateway availability."
			}
		},
		{
			"name": "Upload DCE",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "X-API-Key",
						"value": "{{api_key}}",
						"type": "text"
					}
				],
				"body": {
					"mode": "formdata",
					"formdata": [
						{
							"key": "document",
							"type": "file",
							"src": []
						}
					]
				},
				"url": {
					"raw": "http://localhost:8070/api/v1/upload",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8070",
					"path": [
						"api",
						"v1",
						"upload"
					]
				},
				"description": "Uploads a multipart file to MinIO and returns the storage URI."
			}
		},
		{
			"name": "Pricing via Excel",
			"request": {
				"method": "GET",
				"header": [
					{
						"key": "X-API-Key",
						"value": "{{api_key}}",
						"type": "text"
					}
				],
				"url": {
					"raw": "http://localhost:8070/api/v1/price?source=excel&code=ART01",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8070",
					"path": [
						"api",
						"v1",
						"price"
					],
					"query": [
						{
							"key": "source",
							"value": "excel"
						},
						{
							"key": "code",
							"value": "ART01"
						}
					]
				},
				"description": "Fetches item pricing using the Excel strategy adapter."
			}
		},
		{
			"name": "Security Rejection",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "http://localhost:8070/api/v1/price?source=excel&code=ART01",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8070",
					"path": [
						"api",
						"v1",
						"price"
					],
					"query": [
						{
							"key": "source",
							"value": "excel"
						},
						{
							"key": "code",
							"value": "ART01"
						}
					]
				},
				"description": "Validates HTTP 401 Unauthorized response for missing API key."
			}
		}
	]
}